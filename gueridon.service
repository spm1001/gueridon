[Unit]
Description=Guéridon - Mobile web UI for Claude Code
After=network.target tailscaled.service

[Service]
Type=simple
# Replace YOUR_USER with the unix user who runs the bridge
User=YOUR_USER
WorkingDirectory=/opt/gueridon
Environment=HOME=/home/YOUR_USER
Environment=PATH=/home/YOUR_USER/.local/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=/opt/gueridon/.env
EnvironmentFile=/home/YOUR_USER/Repos/dotfiles/shell/claude-vertex.env
ExecStart=/opt/gueridon/node_modules/.bin/tsx server/bridge.ts
KillMode=control-group
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
