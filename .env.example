# Gueridon environment — copy to .env and fill in real values.
# The systemd service loads this via EnvironmentFile=.

# Required: your Tailscale HTTPS hostname (used for CORS origin)
TAILSCALE_HOSTNAME=your-host.your-tailnet.ts.net

# Push notification sender identity (mailto: URI)
VAPID_SUBJECT=mailto:you@example.com

# Suppress CC's built-in MCP server auto-discovery
ENABLE_CLAUDEAI_MCP_SERVERS=false

# Optional: override bridge listen port (default 3001)
# BRIDGE_PORT=3001

# Optional: VertexAI billing — set these to route CC through GCP instead of Anthropic API
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=global
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-sonnet-4-6

# Optional: override the model CC uses (e.g. "opus", "sonnet")
# CC_MODEL=opus
