# Gueridon environment — copy to .env and fill in real values.
# The systemd service loads this via EnvironmentFile=.

# Required: your Tailscale HTTPS hostname (used for CORS origin)
TAILSCALE_HOSTNAME=your-host.your-tailnet.ts.net

# Push notification sender identity (mailto: URI)
VAPID_SUBJECT=mailto:you@example.com

# Suppress CC's built-in MCP server auto-discovery
ENABLE_CLAUDEAI_MCP_SERVERS=false

# Optional: override bridge listen port (default 3001)
# BRIDGE_PORT=3001
